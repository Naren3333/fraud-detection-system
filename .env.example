ANALYTICS_PROJECTION_PREFIX=analytics

EMAIL_ENABLED=true
EMAIL_PROVIDER=mock
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@frauddetection.com
EMAIL_FROM_NAME=Fraud Detection System

SMS_ENABLED=true
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

NOTIFICATION_CUSTOMER_FALLBACK_EMAIL=demo-customer@frauddetection.com
NOTIFICATION_CUSTOMER_FALLBACK_PHONE=+15550000000
