# Copy this file to .env for local development.
# Replace all secrets before using the stack outside a local demo machine.

PLATFORM_JWT_SECRET=change-me-dev-jwt-secret
PLATFORM_JWT_REFRESH_SECRET=change-me-dev-refresh-secret

TRANSACTION_DB_NAME=transaction_db
TRANSACTION_DB_USER=txn_user
TRANSACTION_DB_PASSWORD=txn_password

USER_DB_NAME=user_db
USER_DB_USER=user_admin
USER_DB_PASSWORD=user_password

DECISION_DB_NAME=decision_db
DECISION_DB_USER=decision_admin
DECISION_DB_PASSWORD=decision_password

HUMAN_REVIEW_DB_NAME=human_review_db
HUMAN_REVIEW_DB_USER=review_admin
HUMAN_REVIEW_DB_PASSWORD=review_password

APPEAL_DB_NAME=appeal_db
APPEAL_DB_USER=appeal_admin
APPEAL_DB_PASSWORD=appeal_password

AUDIT_DB_NAME=audit_db
AUDIT_DB_USER=audit_admin
AUDIT_DB_PASSWORD=audit_password

INFRA_BIND_HOST=127.0.0.1
INTERNAL_SERVICE_BIND_HOST=127.0.0.1
GATEWAY_BIND_HOST=0.0.0.0
ANALYTICS_BIND_HOST=0.0.0.0
OBSERVABILITY_BIND_HOST=0.0.0.0

API_GATEWAY_HOST_PORT=3000
API_GATEWAY_METRICS_HOST_PORT=9090
TRANSACTION_SERVICE_HOST_PORT=3001
TRANSACTION_METRICS_HOST_PORT=9091
USER_SERVICE_HOST_PORT=3002
FRAUD_DETECTION_SERVICE_HOST_PORT=3003
ML_SCORING_SERVICE_HOST_PORT=3004
ML_SCORING_METRICS_HOST_PORT=9094
DECISION_ENGINE_SERVICE_HOST_PORT=3005
DECISION_ENGINE_METRICS_HOST_PORT=9095
NOTIFICATION_SERVICE_HOST_PORT=3006
NOTIFICATION_METRICS_HOST_PORT=9096
AUDIT_SERVICE_HOST_PORT=3007
AUDIT_METRICS_HOST_PORT=9097
ANALYTICS_SERVICE_HOST_PORT=3008
GRAFANA_HOST_PORT=3009
HUMAN_VERIFICATION_SERVICE_HOST_PORT=3010
APPEAL_SERVICE_HOST_PORT=3011

KAFKA_INTERNAL_HOST_PORT=9092
KAFKA_EXTERNAL_HOST_PORT=9093
KAFKA_EXTERNAL_ADVERTISED_HOST=localhost
REDIS_HOST_PORT=6379
OTEL_GRPC_HOST_PORT=4317
OTEL_HTTP_HOST_PORT=4318
OTEL_HEALTH_HOST_PORT=13133
OTEL_METRICS_HOST_PORT=8889
JAEGER_HOST_PORT=16686
