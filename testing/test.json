    {
      "name": "Test Scenarios",
      "item": [
        {
          "name": "Full Flow - Register \u2192 Login \u2192 Create Transaction",
          "item": [
            {
              "name": "1. Register",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/auth/register",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "auth",
                    "register"
                  ]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"testuser_{{$timestamp}}@example.com\",\n  \"password\": \"TestPass123!\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\"\n}"
                }
              }
            },
            {
              "name": "2. Login",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/auth/login",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "auth",
                    "login"
                  ]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"testuser_{{$timestamp}}@example.com\",\n  \"password\": \"TestPass123!\"\n}"
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "let json = pm.response.json();",
                      "if (json.success) {",
                      "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "3. Create Transaction",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{accessToken}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "X-Idempotency-Key",
                    "value": "flow-test-{{$guid}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/transactions",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "transactions"
                  ]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"customerId\": \"flow_test_customer\",\n  \"merchantId\": \"flow_test_merchant\",\n  \"amount\": 5000.00,\n  \"currency\": \"USD\",\n  \"cardNumber\": \"4111111111111111\",\n  \"cardType\": \"visa\"\n}"
                }
              }
            }
          ]
        },
        {
          "name": "Rate Limit Test (Run 6x quickly)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"wrong@example.com\",\n  \"password\": \"WrongPassword\"\n}"
            }
          }
        },
        {
          "name": "High-Risk Transaction (Fraud Flag Expected)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Idempotency-Key",
                "value": "fraud-test-{{$guid}}"
              },
              {
                "key": "X-Correlation-ID",
                "value": "fraud-corr-{{$timestamp}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"customer_test\",\n  \"merchantId\": \"merchant_test\",\n  \"amount\": 15000.0,\n  \"currency\": \"USD\",\n  \"cardNumber\": \"4111111111111111\",\n  \"cardType\": \"visa\",\n  \"deviceId\": \"device_test\",\n  \"ipAddress\": \"192.168.1.1\",\n  \"location\": {\n    \"country\": \"KP\",\n    \"city\": \"Pyongyang\"\n  },\n  \"metadata\": {\n    \"channel\": \"web\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/transactions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions"
              ]
            },
            "description": "Sends a transaction designed to trigger multiple fraud rules:\n- Amount $15,000 exceeds suspicious threshold ($10,000) \u2192 +30 rule score\n- Country KP (North Korea) is in high-risk list \u2192 +25 rule score\n- Round amount heuristic \u2192 +5 rule score\nExpected: flagged=true in fraud-detection-service logs\n\nVerify result:\n  docker logs fraud-detection-service --tail 10\n\nOr consume scored topic:\n  docker exec -it kafka kafka-console-consumer --bootstrap-server kafka:9092 --topic transaction.scored --from-beginning"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let json = pm.response.json();",
                  "if (json.success && json.data) {",
                  "  pm.collectionVariables.set('transactionId', json.data.transactionId);",
                  "  console.log('High-risk transaction created:', json.data.transactionId);",
                  "  console.log('Check fraud-detection-service logs for flagged=true');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
