{
  "name": "fraud-detection-platform-tests",
  "version": "1.0.0",
  "description": "Complete testing suite for fraud detection platform",
  "scripts": {
    "test": "npm run test:all",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "jest --config=jest.config.js --selectProjects=unit",
    "test:unit:watch": "jest --config=jest.config.js --selectProjects=unit --watch",
    "test:unit:coverage": "jest --config=jest.config.js --selectProjects=unit --coverage",
    "test:integration": "jest --config=jest.config.js --selectProjects=integration --runInBand",
    "test:integration:watch": "jest --config=jest.config.js --selectProjects=integration --watch",
    "test:e2e": "playwright test e2e",
    "test:e2e:ui": "playwright test e2e --ui",
    "test:e2e:debug": "playwright test e2e --debug",
    "test:e2e:headed": "playwright test e2e --headed",
    "test:load": "k6 run load/transaction-load.js",
    "test:load:smoke": "k6 run load/transaction-load.js --vus 10 --duration 30s",
    "test:load:stress": "k6 run load/transaction-load.js --vus 500 --duration 5m",
    "test:load:soak": "k6 run load/transaction-load.js --vus 100 --duration 30m",
    "test:security": "npm run test:security:deps && npm run test:security:scan",
    "test:security:deps": "npm audit --audit-level=moderate",
    "test:security:scan": "echo \"No security scan script configured yet\"",
    "test:contract": "echo \"No contract test suite configured yet\"",
    "test:ci": "npm run lint && npm run test:unit:coverage && npm run test:integration",
    "test:changed": "jest --config=jest.config.js --onlyChanged",
    "test:single": "jest --config=jest.config.js",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,md}\"",
    "coverage:report": "echo \"Open coverage report at reports/coverage/lcov-report/index.html\"",
    "coverage:upload": "codecov",
    "docker:test:up": "docker compose -f docker/docker-compose.test.yml up -d",
    "docker:test:down": "docker compose -f docker/docker-compose.test.yml down -v",
    "docker:test:logs": "docker compose -f docker/docker-compose.test.yml logs -f",
    "setup:test-db": "echo \"No test DB helper script configured yet\"",
    "seed:test-data": "echo \"No seed helper script configured yet\""
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.10",
    "babel-jest": "^29.7.0",
    "codecov": "^3.8.3",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^29.7.0",
    "k6": "^0.0.0",
    "nock": "^13.4.0",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3",
    "@pact-foundation/pact": "^12.2.0"
  },
  "dependencies": {
    "faker": "^5.5.3",
    "factory-girl": "^5.0.4"
  }
}
